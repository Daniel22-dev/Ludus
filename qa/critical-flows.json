{
  "flows": [
    {
      "id": "LUDUS-WORKSHOP",
      "name": "Učitel otevře dílnu",
      "type": "browser",
      "url": "/index.html",
      "expectedText": "Postav hru",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h1"
        }
      ]
    },
    {
      "id": "LUDUS-NAME-TOKEN-REGRESSION",
      "name": "Krátké překlady nepoškodí vlastní jména",
      "type": "static",
      "assertions": [
        {
          "file": "engines/indiana-jones.html",
          "notRegex": "JZAPNUTOES",
          "message": "Vlastní jméno JONES je poškozené překladovou náhradou."
        },
        {
          "file": "engines/stranger-things.html",
          "regex": "<title>",
          "message": "Engine Stranger Things nemá platný dokument."
        }
      ]
    }
  ]
}
